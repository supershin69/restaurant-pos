// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CASHIER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      Role
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  profile Profile?
  orders  Order[]

  @@map("users")
}

model Profile {
  // Using the id as both the Primary Key and the Foreign Key to User
  id              String   @id
  profilePhotoUrl String?  @map("profile_photo_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Food {
  id          String    @id @default(uuid())
  name        String
  description String?
  price       Int
  photoUrl    String    @map("photo_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  promotions PromotionItem[]
  orderItems OrderItem[]

  @@unique([name, isDeleted])
  @@map("foods")
}

model Promotion {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  items PromotionItem[]

  @@map("promotions")
}

model PromotionItem {
  id            String @id @default(uuid())
  promotionId   String @map("promotion_id")
  foodId        String @map("food_id")
  discountPrice Int    @map("discount_price")

  // Relations
  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  food      Food      @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@map("promotion_items")
}

model Table {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "Table 1", "VIP Room A"
  createdAt DateTime @default(now()) @map("created_at")

  orders Order[]

  @@map("tables")
}

model Order {
  id        String    @id @default(uuid())
  cashierId String    @map("cashier_id")
  tableId   String    @map("table_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  cashier User        @relation(fields: [cashierId], references: [id])
  table   Table       @relation(fields: [tableId], references: [id])
  items   OrderItem[]

  @@map("orders")
}

model OrderItem {
  id           String   @id @default(uuid()) // Added PK
  orderId      String   @map("order_id")
  foodId       String   @map("food_id")
  quantity     Int      @default(1) // Added to prevent duplicate rows
  priceAtOrder Int      @map("price_at_order") // Locks in the MMK price dynamically
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  food  Food  @relation(fields: [foodId], references: [id])

  @@map("order_items")
}
